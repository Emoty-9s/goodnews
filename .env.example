# ================================
# GoodNews AI - 환경변수 설정
# ================================

# FMP (Financial Modeling Prep) API
FMP_API_KEY=your_fmp_api_key_here
FMP_BASE_URL=https://financialmodelingprep.com/api/v3

# Anthropic Claude API
ANTHROPIC_API_KEY=your_anthropic_api_key_here
CLAUDE_MODEL=claude-sonnet-4-20250514

# Database (PostgreSQL)
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/goodnews
# Supabase 사용 시: postgresql+asyncpg://postgres:[password]@db.[project-ref].supabase.co:5432/postgres

# Redis (Celery 브로커)
REDIS_URL=redis://localhost:6379/0

# 앱 설정
APP_ENV=development
LOG_LEVEL=INFO

# 뉴스 수집 설정
TICKER_BATCH_SIZE=30          # 한 번에 FMP API에 요청할 티커 수
MAX_NEWS_PER_TICKER=50        # 티커당 최대 뉴스 수
LLM_MAX_TOKENS_MAP=800        # Map 단계 1차 요약 max tokens
LLM_MAX_TOKENS_REDUCE=1500    # Reduce 단계 최종 요약 max tokens

# API 서버
API_HOST=0.0.0.0
API_PORT=8000

# 유니버스 빌드
UNIVERSE_DATA_DIR=./data/universe
UNIVERSE_MIN_MARKET_CAP=100000000.0
UNIVERSE_EXCHANGES=NASDAQ,NYSE,AMEX
